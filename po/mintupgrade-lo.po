#: usr/lib/linuxmint/mintupgrade/mintupgrade.py:82
#: usr/share/linuxmint/mintupgrade/mintupgrade.ui.h:2
#, python-format
msgid "Upgrade to %s"
msgstr "ອັບເກດເປັນ %s"

#: usr/lib/linuxmint/mintupgrade/mintupgrade.py:98
msgid "Preferences"
msgstr "ການຕັ້ງຄ່າ"

#: usr/lib/linuxmint/mintupgrade/mintupgrade.py:103
#: usr/lib/linuxmint/mintupgrade/mintupgrade.py:291
msgid "About"
msgstr "ກ່ຽວກັບ"

#: usr/lib/linuxmint/mintupgrade/mintupgrade.py:108
