#: usr/lib/linuxmint/mintupgrade/mintupgrade.py:152
msgid "Phase 1: Preparation"
msgstr "ຂັ້ນຕອນທີ 1: ການກະກຽມ"

#: usr/lib/linuxmint/mintupgrade/mintupgrade.py:153
msgid ""
"A series of tests will now be performed to prepare the computer for the "
"upgrade."
msgstr "ຈະມີການທົດສອບຫຼາຍໆຢ່າງເພື່ອະກຽມຄອມພິວເຕີສຳລັບການອັບເກດ."

#: usr/lib/linuxmint/mintupgrade/mintupgrade.py:165
msgid "Phase 2: Simulation and download"
msgstr "ຂັ້ນຕອນທີ 2: ການຈຳລອງ ແລະ ດາວໂຫຼດ"

#: usr/lib/linuxmint/mintupgrade/mintupgrade.py:166
msgid "Your package repositories will now point towards the new release."
msgstr "ຄັງເກັບແພັກເກດຂອງທ່ານຕອນນີ້ຈະຊີ້ໄປຫາລຸ້ນໃໝ່."

#: usr/lib/linuxmint/mintupgrade/mintupgrade.py:166
msgid "A few more tests will be run and package updates will be downloaded."
msgstr "ຈະມີການທົດສອບເພີ່ມເຕີມ ແລະ ຈະດາວໂຫຼດອັບເດດແພັກເກດ."

#: usr/lib/linuxmint/mintupgrade/mintupgrade.py:172
msgid "Phase 3: Upgrade"
msgstr "ຂັ້ນຕອນທີ 3: ອັບເກດ"

#: usr/lib/linuxmint/mintupgrade/mintupgrade.py:173
msgid "The packages will now be upgraded."
msgstr "ຕອນນີ້ແພັກເກດຈະຖືກອັບເກດ."

#: usr/share/linuxmint/mintupgrade/mintupgrade.ui.h:3
msgid ""
"This program will ask you some questions and upgrade your operating system."
msgstr "ໂປຣແກຣມນີ້ຈະຖາມທ່ານບາງຄຳຖາມ ແລະ ອັບເກດລະບົບປະຕິບັດການຂອງທ່ານ."

#: usr/share/linuxmint/mintupgrade/mintupgrade.ui.h:4
msgid "Let's go!"
msgstr "ໄປກັນເລີຍ!"

#: usr/share/linuxmint/mintupgrade/mintupgrade.ui.h:5
msgid "OK"
msgstr "ຕົກລົງ"

#: usr/share/linuxmint/mintupgrade/mintupgrade.ui.h:6
msgid "Fix"
msgstr "ແກ້ໄຂ"

#: usr/share/linuxmint/mintupgrade/mintupgrade.ui.h:7
msgid "Check again"
msgstr "ກວດສອບອີກຄັ້ງ"

#: usr/share/linuxmint/mintupgrade/mintupgrade.ui.h:8
msgid "The following error occurred:"
msgstr "ເກີດຂໍ້ຜິດພາດຕໍ່ໄປນີ້:"

#: usr/share/linuxmint/mintupgrade/mintupgrade.ui.h:9
msgid "The upgrade was successful."
msgstr "ການອັບເກດສຳເລັດແລ້ວ."

#: usr/share/linuxmint/mintupgrade/mintupgrade.ui.h:10
msgid "Reboot the computer for all the changes to take effect."
msgstr "ເປີດຄອມພິວເຕີຄືນໃໝ່ເພື່ອໃຫ້ການປ່ຽນແປງທັງໝົດມີຜົນ."

#: usr/share/linuxmint/mintupgrade/mintupgrade.ui.h:11
msgid "Recent Timeshift snapshot"
msgstr "ພາບຖ່າຍ Timeshift ຫຼ້າສຸດ"

#: usr/share/linuxmint/mintupgrade/mintupgrade.ui.h:12
msgid "Applied software updates"
msgstr "ນຳໃຊ້ອັບເດດຊອບແວແລ້ວ"

#: usr/share/linuxmint/mintupgrade/mintupgrade.ui.h:13
msgid ""
"These requirements are there to guarantee a safe upgrade. Only disable them "
"if you know what you are doing."
msgstr ""
"ຂໍ້ກຳນົດເຫຼົ່ານີ້ມີໄວ້ເພື່ອຮັບປະກັນການອັບເກດທີ່ປອດໄພ. "
"ປິດໃຊ້ງານພວກມັນກໍຕໍ່ເມື່ອທ່ານຮູ້ວ່າກຳລັງເຮັດຫຍັງຢູ່."

#: usr/share/linuxmint/mintupgrade/mintupgrade.ui.h:14
msgid "Supported Linux Mint version"
msgstr "ລຸ້ນ Linux Mint ທີ່ຮອງຮັບ"

#: usr/share/linuxmint/mintupgrade/mintupgrade.ui.h:15
msgid "Requirements"
msgstr "ຂໍ້ກຳນົດ"
