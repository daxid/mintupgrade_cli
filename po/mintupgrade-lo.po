#: usr/lib/linuxmint/mintupgrade/checks.py:32
#, python-format
msgid ""
"The package repositories need to point towards the new release (%s/%s)."
msgstr "ຄັງເກັບແພັກເກດຈຳເປັນຕ້ອງຊີ້ໄປຫາລຸ້ນໃໝ່ (%s/%s)."

#: usr/lib/linuxmint/mintupgrade/checks.py:34
msgid "This should have be done by the Upgrade Tool already."
msgstr "ສິ່ງນີ້ຄວນຈະເຮັດໂດຍເຄື່ອງມືອັບເກດແລ້ວ."

#: usr/lib/linuxmint/mintupgrade/checks.py:35
msgid "Were the repositories modified since?"
msgstr "ຄັງເກັບຂໍ້ມູນຖືກດັດແກ້ແລ້ວບໍ?"

#: usr/lib/linuxmint/mintupgrade/checks.py:36
msgid "Re-run the Upgrade tool so that it migrates the repositories again."
msgstr "ເປີດໃຊ້ເຄື່ອງມືອັບເກດຄືນໃໝ່ເພື່ອໃຫ້ມັນຍ້າຍຄັງເກັບຂໍ້ມູນອີກຄັ້ງ."

#: usr/lib/linuxmint/mintupgrade/checks.py:143
msgid "Linux Mint version"
msgstr "ລຸ້ນຂອງ Linux Mint"

#: usr/lib/linuxmint/mintupgrade/checks.py:143
msgid "Checking your version of Linux Mint..."
msgstr "ກຳລັງກວດສອບລຸ້ນ Linux Mint ຂອງທ່ານ..."

#: usr/lib/linuxmint/mintupgrade/checks.py:151
msgid ""
"Your version of Linux Mint is unknown. /etc/linuxmint/info is missing."
msgstr "ບໍ່ຮູ້ລຸ້ນ Linux Mint ຂອງທ່ານ. ໄຟລ໌ /etc/linuxmint/info ບໍ່ມີຢູ່."

#: usr/lib/linuxmint/mintupgrade/checks.py:168
#, python-format
msgid "Your version of Linux Mint is '%s'. Only %s can be upgraded to %s."
msgstr ""
"ລຸ້ນ Linux Mint ຂອງທ່ານແມ່ນ '%s'. ສາມາດອັບເກດໄດ້ສະເພາະ %s ເປັນ %s ເທົ່ານັ້ນ."

#: usr/lib/linuxmint/mintupgrade/checks.py:174
#, python-format
msgid "Your edition of Linux Mint is '%s'. It cannot be upgraded to %s."
msgstr "ລຸ້ນ Linux Mint ຂອງທ່ານແມ່ນ '%s'. ມັນບໍ່ສາມາດອັບເກດເປັນ %s ໄດ້."

#: usr/lib/linuxmint/mintupgrade/checks.py:180
#, python-format
msgid "Your architecture of Linux Mint is '%s'. It cannot be upgraded."
msgstr "ສະຖາປັດຕະຍະກຳ Linux Mint ຂອງທ່ານແມ່ນ '%s'. ມັນບໍ່ສາມາດອັບເກດໄດ້."

#: usr/lib/linuxmint/mintupgrade/checks.py:187
msgid "Power source"
msgstr "ແຫຼ່ງພະລັງງານ"

#: usr/lib/linuxmint/mintupgrade/checks.py:187
msgid "Checking the power source..."
msgstr "ກຳລັງກວດສອບແຫຼ່ງພະລັງງານ..."

#: usr/lib/linuxmint/mintupgrade/checks.py:192
msgid "Connect the computer to a power source before attempting to upgrade."
msgstr "ເຊື່ອມຕໍ່ຄອມພິວເຕີກັບແຫຼ່ງພະລັງງານກ່ອນທີ່ຈະພະຍາຍາມອັບເກດ."

#: usr/lib/linuxmint/mintupgrade/checks.py:198
msgid "System snapshots"
msgstr "ພາບຖ່າຍລະບົບ"

#: usr/lib/linuxmint/mintupgrade/checks.py:198
msgid "Checking system snapshots..."
msgstr "ກຳລັງກວດສອບພາບຖ່າຍລະບົບ..."

#: usr/lib/linuxmint/mintupgrade/checks.py:203
msgid ""
"If the upgrade isn't successful, a system snapshot will allow you to go back "
"in time and revert all the changes."
msgstr ""
"ຖ້າການອັບເກດບໍ່ສຳເລັດ, ພາບຖ່າຍລະບົບຈະຊ່ວຍໃຫ້ທ່ານສາມາດກັບຄືນໄປໃນເວລາ ແລະ "
"ຍົກເລີກການປ່ຽນແປງທັງໝົດ."

#: usr/lib/linuxmint/mintupgrade/checks.py:204
msgid "Press 'Fix' to perform a system snapshot."
msgstr "ກົດ 'ແກ້ໄຂ' ເພື່ອສ້າງພາບຖ່າຍລະບົບ."

#: usr/lib/linuxmint/mintupgrade/checks.py:220
msgid "APT cache"
msgstr "ແຄດ APT"

#: usr/lib/linuxmint/mintupgrade/checks.py:220
msgid "Checking the APT cache..."
msgstr "ກຳລັງກວດສອບແຄດ APT..."

#: usr/lib/linuxmint/mintupgrade/checks.py:238
msgid ""
"Your package cache can't refresh correctly. Run 'apt update' and fix the "
"errors it displays."
msgstr ""
"ແຄດແພັກເກດຂອງທ່ານບໍ່ສາມາດໂຫຼດຂໍ້ມູນຄືນໃໝ່ໄດ້ຢ່າງຖືກຕ້ອງ. ໃຊ້ຄຳສັ່ງ 'apt "
"update' ແລະ ແກ້ໄຂຂໍ້ຜິດພາດທີ່ມັນສະແດງ."

#: usr/lib/linuxmint/mintupgrade/checks.py:247
msgid ""
"Some of your packages are broken. Run 'apt install -f' to fix the issue."
msgstr ""
"ບາງແພັກເກດຂອງທ່ານມີບັນຫາ. ໃຊ້ຄຳສັ່ງ 'apt install -f' ເພື່ອແກ້ໄຂບັນຫາ."

#: usr/lib/linuxmint/mintupgrade/checks.py:258
msgid ""
"Your operating system is not up to date. Apply available updates before "
"attempting the upgrade."
msgstr ""
"ລະບົບປະຕິບັດການຂອງທ່ານບໍ່ແມ່ນລຸ້ນລ່າສຸດ. "
"ຕິດຕັ້ງອັບເດດທີ່ມີຢູ່ກ່ອນທີ່ຈະພະຍາຍາມອັບເກດ."

#: usr/lib/linuxmint/mintupgrade/checks.py:279
msgid "The following operations need to be performed:"
msgstr "ການດຳເນີນການຕໍ່ໄປນີ້ຈຳເປັນຕ້ອງເຮັດ:"

#: usr/lib/linuxmint/mintupgrade/checks.py:281
#: usr/lib/linuxmint/mintupgrade/checks.py:503
msgid "Package"
msgstr "ແພັກເກດ"

#: usr/lib/linuxmint/mintupgrade/checks.py:281
msgid "Operation"
msgstr "ການດຳເນີນການ"

#: usr/lib/linuxmint/mintupgrade/checks.py:283
msgid "needs to be installed"
msgstr "ຈຳເປັນຕ້ອງຕິດຕັ້ງ"

#: usr/lib/linuxmint/mintupgrade/checks.py:285
msgid "needs to be removed"
msgstr "ຈຳເປັນຕ້ອງຖອນການຕິດຕັ້ງ"

#: usr/lib/linuxmint/mintupgrade/checks.py:314
#: usr/lib/linuxmint/mintupgrade/checks.py:603
msgid "Package repositories"
msgstr "ຄັງເກັບແພັກເກດ"

#: usr/lib/linuxmint/mintupgrade/checks.py:314
msgid "Checking package repositories..."
msgstr "ກຳລັງກວດສອບຄັງເກັບແພັກເກດ..."

#: usr/lib/linuxmint/mintupgrade/checks.py:328
msgid ""
"The following sources are defined in DEB822 format. This format isn't "
"supported yet."
msgstr ""
"ແຫຼ່ງຂໍ້ມູນຕໍ່ໄປນີ້ຖືກກຳນົດໃນຮູບແບບ DEB822. ຮູບແບບນີ້ຍັງບໍ່ຮອງຮັບເທື່ອ."

#: usr/lib/linuxmint/mintupgrade/checks.py:334
msgid "Backup and then delete these files to continue."
msgstr "ສຳຮອງຂໍ້ມູນ ແລະ ລົບໄຟລ໌ເຫຼົ່ານີ້ເພື່ອດຳເນີນການຕໍ່."

#: usr/lib/linuxmint/mintupgrade/checks.py:362
msgid ""
"The following repositories do not explicitly support your version of Linux "
"Mint."
msgstr "ຄັງເກັບຂໍ້ມູນຕໍ່ໄປນີ້ບໍ່ໄດ້ຮອງຮັບລຸ້ນ Linux Mint ຂອງທ່ານຢ່າງຊັດເຈນ."

#: usr/lib/linuxmint/mintupgrade/checks.py:370
msgid "These repositories need to be disabled."
msgstr "ຄັງເກັບຂໍ້ມູນເຫຼົ່ານີ້ຈຳເປັນຕ້ອງຖືກປິດໃຊ້ງານ."

#: usr/lib/linuxmint/mintupgrade/checks.py:383
msgid "Your APT policy is incorrect."
msgstr "ນະໂຍບາຍ APT ຂອງທ່ານບໍ່ຖືກຕ້ອງ."

#: usr/lib/linuxmint/mintupgrade/checks.py:384
msgid "Reboot your computer."
msgstr "ເປີດຄອມພິວເຕີຂອງທ່ານຄືນໃໝ່."

#: usr/lib/linuxmint/mintupgrade/checks.py:392
#: usr/lib/linuxmint/mintupgrade/checks.py:409
#, python-format
msgid "%s is unreachable"
msgstr "%s ບໍ່ສາມາດເຂົ້າເຖິງໄດ້"

#: usr/lib/linuxmint/mintupgrade/checks.py:414
#, python-format
msgid "%s is not up to date. Switch to a different mirror."
msgstr "%s ບໍ່ແມ່ນລຸ້ນລ່າສຸດ. ປ່ຽນໄປໃຊ້ mirror ອື່ນ."

#: usr/lib/linuxmint/mintupgrade/checks.py:422
#, python-format
msgid "%s does not support %s"
msgstr "%s ບໍ່ຮອງຮັບ %s"

#: usr/lib/linuxmint/mintupgrade/checks.py:426
msgid "The following problems were found:"
msgstr "ພົບ​ບັນ​ຫາ​ດັ່ງ​ຕໍ່​ໄປ​ນີ້:"

#: usr/lib/linuxmint/mintupgrade/checks.py:468
msgid "Held packages"
msgstr "ແພັກເກດທີ່ຖືກກັກໄວ້"

#: usr/lib/linuxmint/mintupgrade/checks.py:468
msgid "Looking for held packages..."
msgstr "ກຳລັງຊອກຫາແພັກເກດທີ່ຖືກກັກໄວ້..."

#: usr/lib/linuxmint/mintupgrade/checks.py:474
msgid "The following packages are held:"
msgstr "ແພັກເກດຕໍ່ໄປນີ້ຖືກກັກໄວ້:"

#: usr/lib/linuxmint/mintupgrade/checks.py:481
msgid "Held packages can break the upgrade."
msgstr "ແພັກເກດທີ່ຖືກກັກໄວ້ສາມາດເຮັດໃຫ້ການອັບເກດລົ້ມເຫຼວ."

#: usr/lib/linuxmint/mintupgrade/checks.py:495
msgid "Foreign packages"
msgstr "ແພັກເກດຈາກພາຍນອກ"

#: usr/lib/linuxmint/mintupgrade/checks.py:495
msgid "Looking for foreign packages..."
msgstr "ກຳລັງຊອກຫາແພັກເກດຈາກພາຍນອກ..."

#: usr/lib/linuxmint/mintupgrade/checks.py:501
msgid ""
"The following packages need to be downgraded back to official versions:"
msgstr "ແພັກເກດຕໍ່ໄປນີ້ຈຳເປັນຕ້ອງຖືກດາວເກດກັບຄືນເປັນລຸ້ນທາງການ:"

#: usr/lib/linuxmint/mintupgrade/checks.py:503
msgid "Installed Version"
msgstr "ລຸ້ນທີ່ຕິດຕັ້ງ"

#: usr/lib/linuxmint/mintupgrade/checks.py:503
msgid "Official version"
msgstr "ລຸ້ນທາງການ"

#: usr/lib/linuxmint/mintupgrade/checks.py:503
msgid "Archive"
msgstr "ສາງເກັບ"

#: usr/lib/linuxmint/mintupgrade/checks.py:508
msgid "Otherwise these packages can create conflicts."
msgstr "ຖ້າບໍ່ດັ່ງນັ້ນ, ແພັກເກດເຫຼົ່ານີ້ສາມາດສ້າງຄວາມຂັດແຍ້ງໄດ້."

#: usr/lib/linuxmint/mintupgrade/checks.py:524
#: usr/lib/linuxmint/mintupgrade/checks.py:564
msgid "Orphan packages"
msgstr "ແພັກເກດກຳພ້າ"

#: usr/lib/linuxmint/mintupgrade/checks.py:524
msgid "Looking for orphan packages..."
msgstr "ກຳລັງຊອກຫາແພັກເກດກຳພ້າ..."

#: usr/lib/linuxmint/mintupgrade/checks.py:546
msgid "The following packages do not exist in the repositories:"
msgstr "ແພັກເກດຕໍ່ໄປນີ້ບໍ່ມີຢູ່ໃນຄັງເກັບຂໍ້ມູນ:"

#: usr/lib/linuxmint/mintupgrade/checks.py:552
msgid "In some rare cases orphan packages can interfere with the upgrade."
msgstr "ໃນບາງກໍລະນີທີ່ຫາຍາກ, ແພັກເກດກຳພ້າສາມາດລົບກວນການອັບເກດໄດ້."

#: usr/lib/linuxmint/mintupgrade/checks.py:553
msgid ""
"If you decide to uninstall some of these packages press 'Check again' after "
"their removal."
msgstr ""
"ຖ້າທ່ານຕັດສິນໃຈຖອນການຕິດຕັ້ງບາງແພັກເກດເຫຼົ່ານີ້, ກົດ 'ກວດສອບອີກຄັ້ງ' "
"ຫຼັງຈາກການຖອນ."

#: usr/lib/linuxmint/mintupgrade/checks.py:554
msgid "Press 'OK' to continue with the upgrade."
msgstr "ກົດ 'ຕົກລົງ' ເພື່ອດຳເນີນການອັບເກດຕໍ່."

#: usr/lib/linuxmint/mintupgrade/checks.py:564
msgid "Removing newly orphaned packages..."
msgstr "ກຳລັງລົບແພັກເກດກຳພ້າທີ່ພົບໃໝ່..."

#: usr/lib/linuxmint/mintupgrade/checks.py:603
msgid "Pointing to the new release..."
msgstr "ກຳລັງຊີ້ໄປຫາລຸ້ນໃໝ່..."

#: usr/lib/linuxmint/mintupgrade/checks.py:642
msgid "Upgrade simulation"
msgstr "ການຈຳລອງການອັບເກດ"

#: usr/lib/linuxmint/mintupgrade/checks.py:642
msgid "Simulating upgrade to check hard disk space and potential issues..."
msgstr ""
"ກຳລັງຈຳລອງການອັບເກດເພື່ອກວດສອບພື້ນທີ່ຮາດດິສ ແລະ ບັນຫາທີ່ອາດຈະເກີດຂຶ້ນ..."

#: usr/lib/linuxmint/mintupgrade/checks.py:681
msgid "The simulation was not successful."
msgstr "ການຈຳລອງບໍ່ສຳເລັດ."

#: usr/lib/linuxmint/mintupgrade/checks.py:682
msgid "Upgrading would remove the following important packages:"
msgstr "ການອັບເກດຈະລົບແພັກເກດທີ່ສຳຄັນຕໍ່ໄປນີ້:"

#: usr/lib/linuxmint/mintupgrade/checks.py:683
msgid "Unwanted removals"
msgstr "ການລົບທີ່ບໍ່ຕ້ອງການ"

#: usr/lib/linuxmint/mintupgrade/checks.py:687
msgid ""
"This is a sign that something is wrong and needs to be fixed before going "
"further."
msgstr ""
"ນີ້ເປັນສັນຍານວ່າບາງຢ່າງຜິດປົກກະຕິ ແລະ "
"ຈຳເປັນຕ້ອງໄດ້ຮັບການແກ້ໄຂກ່ອນທີ່ຈະດຳເນີນການຕໍ່."

#: usr/lib/linuxmint/mintupgrade/checks.py:689
msgid "Recommended solution"
msgstr "ວິທີແກ້ໄຂທີ່ແນະນຳ"

#: usr/lib/linuxmint/mintupgrade/checks.py:690
msgid "Use apt-get in a terminal to troubleshoot and solve the issue."
msgstr "ໃຊ້ apt-get ໃນ terminal ເພື່ອແກ້ໄຂບັນຫາ."

#: usr/lib/linuxmint/mintupgrade/checks.py:691
msgid "Don't hesitate to seek help on the forums and the chat room."
msgstr "ຢ່າລັງເລທີ່ຈະຂໍຄວາມຊ່ວຍເຫຼືອໃນເວທີສົນທະນາ ແລະ ຫ້ອງສົນທະນາ."

#: usr/lib/linuxmint/mintupgrade/checks.py:693
msgid "Additional information"
msgstr "ຂໍ້ມູນເພີ່ມເຕີມ"

#: usr/lib/linuxmint/mintupgrade/checks.py:694
msgid "The information below might help solve the issue."
msgstr "ຂໍ້ມູນຂ້າງລຸ່ມນີ້ອາດຈະຊ່ວຍແກ້ໄຂບັນຫາໄດ້."

#: usr/lib/linuxmint/mintupgrade/checks.py:695
#: usr/lib/linuxmint/mintupgrade/checks.py:707
msgid "Kept packages"
msgstr "ແພັກເກດທີ່ຖືກເກັບໄວ້"

#: usr/lib/linuxmint/mintupgrade/checks.py:696
#: usr/lib/linuxmint/mintupgrade/checks.py:711
msgid "Removed packages"
msgstr "ແພັກເກດທີ່ຖືກລົບ"

#: usr/lib/linuxmint/mintupgrade/checks.py:697
#: usr/lib/linuxmint/mintupgrade/checks.py:710
msgid "Added packages"
msgstr "ແພັກເກດທີ່ເພີ່ມເຂົ້າມາ"

#: usr/lib/linuxmint/mintupgrade/checks.py:698
#: usr/lib/linuxmint/mintupgrade/checks.py:706
#, python-format
msgid "Packages updated: %d, added: %d , kept: %d, deleted: %d"
msgstr "ແພັກເກດທີ່ອັບເດດ: %d, ເພີ່ມ: %d, ເກັບໄວ້: %d, ລົບ: %d"

#: usr/lib/linuxmint/mintupgrade/checks.py:701
msgid "Upgrading will perform the following changes."
msgstr "ການອັບເກດຈະດຳເນີນການປ່ຽນແປງຕໍ່ໄປນີ້."

#: usr/lib/linuxmint/mintupgrade/checks.py:709
msgid ""
"Note: Ideally, no packages should be kept. This might indicate an issue."
msgstr ""
"ໝາຍເຫດ: ໂດຍທົ່ວໄປແລ້ວ, ບໍ່ຄວນມີແພັກເກດໃດຖືກເກັບໄວ້. ນີ້ອາດຈະສະແດງເຖິງບັນຫາ."

#: usr/lib/linuxmint/mintupgrade/checks.py:713
msgid ""
"Go through the list above and make sure you are happy with the removals "
"before going further with the upgrade."
msgstr ""
"ກວດສອບລາຍການຂ້າງເທິງ ແລະ ໃຫ້ແນ່ໃຈວ່າທ່ານພໍໃຈກັບການລົບຕ່າງໆ "
"ກ່ອນທີ່ຈະດຳເນີນການອັບເກດຕໍ່."

#: usr/lib/linuxmint/mintupgrade/checks.py:812
#, python-format
msgid "You need %s on '%s' but only have %s. You must free an additional %s."
msgstr "ທ່ານຕ້ອງການ %s ໃນ '%s' ແຕ່ມີພຽງ %s. ທ່ານຕ້ອງເພີ່ມພື້ນທີ່ຫວ່າງອີກ %s."

#: usr/lib/linuxmint/mintupgrade/checks.py:816
#, python-format
msgid "Download size: %s. Additional space needed: %s."
msgstr "ຂະໜາດດາວໂຫຼດ: %s. ພື້ນທີ່ທີ່ຕ້ອງການເພີ່ມ: %s."

#: usr/lib/linuxmint/mintupgrade/checks.py:822
msgid "Package download"
msgstr "ດາວໂຫຼດແພັກເກດ"

#: usr/lib/linuxmint/mintupgrade/checks.py:822
msgid "Downloading packages..."
msgstr "ກຳລັງດາວໂຫຼດແພັກເກດ..."

#: usr/lib/linuxmint/mintupgrade/checks.py:834
msgid "An error occurred while downloading the packages."
msgstr "ເກີດຂໍ້ຜິດພາດຂະນະດາວໂຫຼດແພັກເກດ."

#: usr/lib/linuxmint/mintupgrade/checks.py:841
msgid "Session inhibition"
msgstr "ການຢັບຢັ້ງເຊດຊັນ"

#: usr/lib/linuxmint/mintupgrade/checks.py:841
msgid "Inhibiting session..."
msgstr "ກຳລັງຢັບຢັ້ງເຊດຊັນ..."

#: usr/lib/linuxmint/mintupgrade/checks.py:850
msgid "Upgrade preparation"
msgstr "ການກະກຽມການອັບເກດ"

#: usr/lib/linuxmint/mintupgrade/checks.py:850
msgid "Preparing the upgrade..."
msgstr "ກຳລັງກະກຽມການອັບເກດ..."

#: usr/lib/linuxmint/mintupgrade/checks.py:879
msgid "Upgrade phase"
msgstr "ຂັ້ນຕອນການອັບເກດ"

#: usr/lib/linuxmint/mintupgrade/checks.py:879
msgid "Upgrading the system..."
msgstr "ກຳລັງອັບເກດລະບົບ..."

#: usr/lib/linuxmint/mintupgrade/checks.py:896
#: usr/lib/linuxmint/mintupgrade/checks.py:902
msgid "An issue was detected during the upgrade."
msgstr "ກວດພົບບັນຫາໃນລະຫວ່າງການອັບເກດ."

#: usr/lib/linuxmint/mintupgrade/checks.py:921
#, python-format
msgid "%d packages still need to be updated (%d kept, %d deleted)"
msgstr "ຍັງມີ %d ແພັກເກດທີ່ຕ້ອງອັບເດດ (%d ເກັບໄວ້, %d ລົບອອກ)"

#: usr/lib/linuxmint/mintupgrade/checks.py:927
msgid "Final phase"
msgstr "ຂັ້ນຕອນສຸດທ້າຍ"

#: usr/lib/linuxmint/mintupgrade/checks.py:927
msgid "Finalizing the upgrade..."
msgstr "ກຳລັງສຳເລັດການອັບເກດ..."

#: usr/lib/linuxmint/mintupgrade/checks.py:946
#, python-format
msgid "%s could not be installed."
msgstr "ບໍ່ສາມາດຕິດຕັ້ງ %s ໄດ້."

#: usr/lib/linuxmint/mintupgrade/checks.py:953
msgid "mint-meta-codecs could not be installed."
msgstr "ບໍ່ສາມາດຕິດຕັ້ງ mint-meta-codecs ໄດ້."

#: usr/lib/linuxmint/mintupgrade/checks.py:973
#: usr/lib/linuxmint/mintupgrade/checks.py:992
msgid "The following packages could not be installed:"
msgstr "ບໍ່ສາມາດຕິດຕັ້ງແພັກເກດຕໍ່ໄປນີ້ໄດ້:"

#: usr/lib/linuxmint/mintupgrade/checks.py:1059
msgid "/etc/fstab was modified during the upgrade."
msgstr "/etc/fstab ຖືກດັດແກ້ໃນລະຫວ່າງການອັບເກດ."

#: usr/lib/linuxmint/mintupgrade/checks.py:1060
msgid ""
"To ensure a successful boot, the upgrade tool restored your original "
"/etc/fstab"
msgstr ""
"ເພື່ອໃຫ້ແນ່ໃຈວ່າການເປີດເຄື່ອງສຳເລັດ, ເຄື່ອງມືອັບເກດໄດ້ກູ້ຄືນໄຟລ໌ /etc/fstab "
"ເດີມຂອງທ່ານ"

#: usr/lib/linuxmint/mintupgrade/checks.py:1061
msgid "A copy of the modified file was saved as /etc/fstab.upgraded"
msgstr "ສຳເນົາຂອງໄຟລ໌ທີ່ຖືກດັດແກ້ໄດ້ຖືກບັນທຶກໄວ້ເປັນ /etc/fstab.upgraded"

#: usr/lib/linuxmint/mintupgrade/mintupgrade.py:71
#: usr/lib/linuxmint/mintupgrade/mintupgrade.py:292 generate_desktop_files:26
